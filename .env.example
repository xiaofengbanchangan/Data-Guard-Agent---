# 选择一种模型配置：

# 1. 使用本地 Ollama（免费）
# 先安装 Ollama: curl -fsSL https://ollama.com/install.sh | sh
# 拉取模型: ollama pull （如qwen2.5:7b） 一个你电脑能用的模型（根据需要来或者自行微调量化）
BASE_URL=http://localhost:11434
MODEL_NAME=ollama/qwen2.5:7b
OPENAI_API_KEY=EMPTY

# 2. 使用阿里云百炼
# BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MODEL_NAME=qwen  （也可以用本地的）
# OPENAI_API_KEY=sk-你的密钥